# ============================================
# AGROTECH | .env.example
#
# ¿QUÉ ES ESTE ARCHIVO?
#   Es una PLANTILLA de variables de entorno.
#   Las variables de entorno son contraseñas/claves
#   que tu app necesita para conectarse a servicios
#   externos (Firebase, bases de datos, etc.)
#
# ¿QUÉ DEBO HACER?
#   1. Copia este archivo y renómbralo a ".env"
#      (sin el ".example")
#   2. Rellena cada valor con tus claves reales
#   3. El archivo ".env" NUNCA debe subirse a GitHub
#      (ya está en .gitignore por seguridad)
#
# ⚠️  REGLA DE ORO DE SEGURIDAD:
#   Si alguien más ve tus claves reales, pueden
#   usar tu Firebase, gastar tu dinero y acceder
#   a los datos de tus clientes. Tratar las claves
#   igual que una contraseña bancaria.
# ============================================

# ---------- Firebase ----------
# Obtén estas claves en: https://console.firebase.google.com
# → Tu Proyecto → ⚙️ Configuración del proyecto → Aplicaciones web

VITE_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto-id
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# ---------- Otros servicios (ejemplos futuros) ----------
# VITE_STRIPE_PUBLIC_KEY=pk_test_XXXXX   ← clave pública de pagos
# VITE_EMAILJS_SERVICE_ID=service_XXXXX  ← para envío de emails
