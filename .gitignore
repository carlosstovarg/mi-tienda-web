# ============================================
# AGROTECH | .gitignore
# Archivos que NUNCA deben subirse a GitHub
# ============================================

# Variables de entorno con claves secretas
.env
.env.local
.env.production

# Dependencias (se reinstalan con npm install)
node_modules/

# Archivos del sistema operativo
.DS_Store
Thumbs.db

# Logs de errores
*.log
npm-debug.log*
